{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://frd-nutrition.onrender.com/sitemap.xml"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!api|assets|uploads).*)",
      "destination": "https://frd-nutrition.onrender.com/$1"
    }
  ]
}
